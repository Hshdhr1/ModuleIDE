<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:background="@color/chat_primary_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingLeft="16dp"
        android:paddingTop="16dp"
        android:paddingRight="16dp"
        android:paddingBottom="12dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <ImageView
            android:id="@+id/chat_back"
            android:padding="6dp"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/icon_arrow_back_round"
            android:tint="@color/chat_on_primary_container" />

        <TextView
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/chat_on_primary_container"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="8dp"
            android:text="AI Chat" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:orientation="vertical"
            android:padding="16dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <LinearLayout
                android:gravity="end"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <LinearLayout
                    android:orientation="vertical"
                    android:background="@drawable/bg_chat_user_bubble"
                    android:padding="14dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="48dp">

                    <TextView
                        android:textSize="14sp"
                        android:textColor="@color/chat_on_primary"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Что делает этот плагин и как он взаимодействует с telegram stars" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:layout_marginRight="48dp">

                <ImageView
                    android:layout_gravity="top"
                    android:layout_width="34dp"
                    android:layout_height="34dp"
                    android:padding="6dp"
                    android:src="@drawable/icon_auto_awesome_round"
                    android:tint="@color/chat_primary"
                    android:background="@drawable/bg_chat_ai_icon" />

                <LinearLayout
                    android:orientation="vertical"
                    android:background="@drawable/bg_chat_ai_bubble"
                    android:padding="14dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="10dp">

                    <TextView
                        android:id="@+id/chat_ai_model_name"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="@color/chat_primary"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Gemini 3.1 pro" />

                    <TextView
                        android:textSize="14sp"
                        android:textColor="@color/chat_on_primary_container"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="Этот плагин узнает сколько Telegram звезд у пользователя и отправляет их в чат." />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

</LinearLayout>
